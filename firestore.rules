rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to submit a Join Request (Write only)
    match /join_requests/{document=**} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    // Allow anyone to submit a Mentor Application (Write only)
    match /mentor_applications/{document=**} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    // Allow anyone to submit a Donation Pledge (Write only)
    match /donations/{document=**} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    
    // Deny access to everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}



